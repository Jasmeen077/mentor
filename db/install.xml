<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/mentor/db" VERSION="20240327" COMMENT="XMLDB file for Moodle local/mentor"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
    <TABLES>

        <TABLE NAME="local_mentor" COMMENT="Stores mentor ratings per user and course">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <!-- <FIELD NAME="teacherid" TYPE="int" LENGTH="10" NOTNULL="true"/> -->
                <FIELD NAME="rating" TYPE="int" LENGTH="2" NOTNULL="true"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>

            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="userid_fk" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
                <KEY NAME="courseid_fk" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
                 <!-- <KEY NAME="teacherid_fk" TYPE="foreign" FIELDS="teacherid" REFTABLE="user" REFFIELDS="id"/> -->
            </KEYS>

            <INDEXES>
                <INDEX NAME="userid_idx" UNIQUE="false" FIELDS="userid"/>
                <INDEX NAME="courseid_idx" UNIQUE="false" FIELDS="courseid"/>
                <!-- <INDEX NAME="teacherid_idx" UNIQUE="false" FIELDS="teacherid"/> -->
            </INDEXES>
        </TABLE>


        <TABLE NAME="local_mentor_rates_log" COMMENT="Stores mentor rating logs">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="mentor_id" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="rate" TYPE="int" LENGTH="2" NOTNULL="true"/>
                <FIELD NAME="reason" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>

            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="mentorid_fk" TYPE="foreign" FIELDS="mentor_id" REFTABLE="local_mentor" REFFIELDS="id"/>
            </KEYS>

            <INDEXES>
                <INDEX NAME="mentorid_idx" UNIQUE="false" FIELDS="mentor_id"/>
            </INDEXES>
        </TABLE>

    </TABLES>
</XMLDB>